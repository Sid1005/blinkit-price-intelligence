        "w1_system_user_prompts": {"desc": "System vs user prompt engineering", "status": "covered", "evidence": "app/ingest/scraper.py::ANALYST_SYSTEM", "eval_evidence": "evals/harness.py::model_tournament (system prompts)"},
        "w1_streaming": {"desc": "Token streaming", "status": "covered", "evidence": "app/llm/groq_client.py::stream", "eval_evidence": "app/ui.py::chat_fn (live)"},
