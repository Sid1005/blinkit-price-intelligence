# Price Intelligence — copy to `.env` (repo root) and fill in.
# config.py loads this file automatically; nothing is hardcoded.

# Runtime LLM calls: rewrite, parse, price, RAG (REQUIRED) — https://console.groq.com
GROQ_API_KEY=

# Second frontier arm: Claude pricing + no-RAG substitution — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Live Blinkit scraping — https://tavily.com
TAVILY_API_KEY=

# Hugging Face: embeddings, open models, curated-dataset Hub push/pull
# https://huggingface.co/settings/tokens
HF_TOKEN=
