# India Commerce SignalForge — copy to `.env` (repo root) and fill in.
# config.py loads this file automatically; nothing is hardcoded.

# Runtime LLM calls (REQUIRED) — https://console.groq.com
GROQ_API_KEY=

# Claude frontier pricing arm (zero-shot, no RAG) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Web evidence scraping (Tavily) — https://tavily.com
TAVILY_API_KEY=

# Hugging Face: model downloads + optional LoRA Hub publish — https://huggingface.co/settings/tokens
HF_TOKEN=

# Gemini translation (REST streaming; realtime Live API optional, see RUNBOOK §14)
GEMINI_API_KEY=

# Experiment tracking (OPTIONAL; falls back to offline JSONL if unset)
WANDB_API_KEY=
# WANDB_MODE=offline

# High-confidence alert webhook (OPTIONAL; logs locally if unset)
SIGNALFORGE_WEBHOOK_URL=
